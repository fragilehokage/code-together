# MongoDB Atlas connection string (required)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/collaborative_ide?retryWrites=true&w=majority

# Optional: override default database name
# MONGO_DB_NAME=collaborative_ide

# Google Gemini API key (optional — enables AI chat and fix)
GEMINI_API_KEY=your_gemini_api_key_here

# Server port (default: 4050)
PORT=4050

# Comma-separated allowed browser origins for CORS (dev + production URLs)
CLIENT_ORIGIN=http://localhost:5173,http://localhost:4173,http://localhost:4050

# Set to production when deploying
NODE_ENV=production
